# Provider selection
# LLM_PROVIDER=openai
# Supported: openai, openai-chat, deepseek, qwen, moonshot, zhipu, custom-chat

# OpenAI Responses API
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# DeepSeek
# DEEPSEEK_API_KEY=
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-v4-pro

# Alibaba Qwen / DashScope OpenAI-compatible API
# DASHSCOPE_API_KEY=
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus

# Moonshot / Kimi OpenAI-compatible API
# MOONSHOT_API_KEY=
# LLM_PROVIDER=moonshot
# LLM_MODEL=moonshot-v1-128k

# Zhipu / GLM OpenAI-compatible API
# ZHIPU_API_KEY=
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-plus

# Custom OpenAI-compatible Chat Completions provider
# LLM_PROVIDER=custom-chat
# LLM_API_KEY_ENV=LLM_API_KEY
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# Runtime settings
# LLM_TIMEOUT_SECONDS=60
# DEFAULT_AUDIENCE=executives
# MAX_FINDINGS=5
# MIN_SOURCE_BACKED_FINDINGS=3
